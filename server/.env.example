# 复制此文件为 .env 并填入真实值。.env 不要提交到 Git。
# Copy this file to .env and fill in real values. Never commit .env.

# Google Gemini API key（全品类组图分析等会用到，仅后端使用）
# 在 https://aistudio.google.com/app/apikey 申请
GEMINI_API_KEY=

# 可选：JWT 密钥，不设则使用默认开发值
# JWT_SECRET=your_jwt_secret_here

# 可选：服务端口，默认 3001
# PORT=3001

# 可选：代理（后端访问 Google 时使用，浏览器代理不会自动生效）
# 例如 Clash 默认本地端口 7890：HTTPS_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# 管理员账号（首次启动自动创建/提升为 admin）
# 若该邮箱已注册，只提升角色，不修改密码
# 若该邮箱未注册，同时填写 ADMIN_PASSWORD 自动创建账号
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=your_admin_password

# 腾讯云 COS（可选，配置后新图会同步上传 COS，列表返回临时签名 URL，国内访问加速）
# 在腾讯云控制台：对象存储 → 存储桶 → 创建；访问管理 → API 密钥 → 创建
# COS_SECRET_ID=
# COS_SECRET_KEY=
# COS_BUCKET=your-bucket-1250000000
# COS_REGION=ap-guangzhou
# 可选：CDN 加速域名（如 img.pictoolai.studio），配置后签名 URL 使用该域名
# COS_CDN_DOMAIN=

# 侵权风险「深度查询」：SerpApi（Google Lens + 专利检索），不配置则深度查询不可用
# 在 https://serpapi.com/ 注册，Developer 套餐约 $75/月
# SERPAPI_KEY=
